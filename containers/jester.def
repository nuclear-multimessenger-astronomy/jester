Bootstrap: docker
From: nvidia/cuda:12.2.0-cudnn8-runtime-rockylinux9

%post
    # System dependencies
    dnf install -y python3.12 python3.12-pip git curl
    ln -sf /usr/bin/python3.12 /usr/local/bin/python3
    ln -sf /usr/bin/python3.12 /usr/local/bin/python

    # uv (fast Python package installer)
    curl -LsSf https://astral.sh/uv/install.sh | INSTALLER_NO_MODIFY_PATH=1 sh
    export PATH="/root/.local/bin:$PATH"

    # Install JESTER with CUDA 12 support.
    # blackjax is a git dependency — internet access required at build time.
    git clone https://github.com/nuclear-multimessenger-astronomy/jester.git /opt/jester
    cd /opt/jester
    uv pip install --system -e ".[cuda12]"

    # Verify the entry point landed
    which run_jester_inference

    # Clean up to reduce image size
    dnf clean all
    pip3.12 cache purge 2>/dev/null || true

%environment
    export PATH="/root/.local/bin:/usr/local/bin:$PATH"
    export JAX_ENABLE_X64=1

%runscript
    exec run_jester_inference "$@"

%labels
    Author thibeau.wouters
    Description JESTER neutron-star inference — Python 3.12, CUDA 12, Rocky Linux 9

%help
    JESTER Apptainer image with GPU (CUDA 12) support.

    Build on CIT (requires internet access for the blackjax git dependency):
        apptainer build /home/thibeau.wouters/jester_analyses/jester.sif jester.def

    Or build with Docker locally and transfer (see Dockerfile):
        docker build -t jester .
        apptainer build jester.sif docker-daemon://jester:latest
        scp jester.sif thibeau.wouters@ldas-pcdev1.ligo.caltech.edu:/home/thibeau.wouters/jester_analyses/

    Test interactively on a CIT node:
        apptainer exec --nv jester.sif run_jester_inference config.yaml --dry-run

    Submit via HTCondor:
        cd examples/inference/cit_example
        condor_submit submit.sub
